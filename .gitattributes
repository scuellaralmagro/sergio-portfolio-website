# Normalize line endings to LF in the repo (Windows author).
* text=auto eol=lf

# Explicit text types
*.astro   text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.mjs     text eol=lf
*.json    text eol=lf
*.css     text eol=lf
*.md      text eol=lf
*.svg     text eol=lf

# Binary assets — never normalize
*.woff2   binary
*.woff    binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.webp    binary
*.avif    binary
*.ico     binary
*.pdf     binary

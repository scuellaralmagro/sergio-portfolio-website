# Copy to .env and fill in. Frontend-only, PUBLIC (build-embedded) values —
# the RAG API's server secrets live in the separate sergio-portfolio-api repo.

# Cloudflare Turnstile — PUBLIC site key of the widget whose secret is set on the
# api.sergiocuellar.dev Worker (hostnames must include sergiocuellar.dev + localhost).
PUBLIC_TURNSTILE_SITE_KEY=

# Optional: point the "Ask my portfolio" console at a local Worker during development.
# PUBLIC_API_BASE_URL=http://localhost:8787

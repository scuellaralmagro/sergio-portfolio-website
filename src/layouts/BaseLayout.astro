---
/**
 * BaseLayout — document shell for every page.
 * Owns <head> (meta, OG/Twitter, JSON-LD), font loading, the skip-link,
 * and the global stylesheet. Keep page components free of <head> concerns.
 */
import '@fontsource-variable/inter';
import '@fontsource-variable/dm-sans';
import '../styles/global.css';
import { site, personSchema } from '../data/site';
import { useTranslations, localizedPath, type Locale } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  /** Path-only OG image override, e.g. "/og/project-x.png" */
  ogImage?: string;
  /** Exclude from search engines (e.g. internal styleguide). */
  noindex?: boolean;
  /**
   * Opt a page into i18n behaviour: hreflang alternates + the first-visit
   * language-detection redirect. Public pages that exist in both locales set
   * this; internal pages (styleguide, vault) leave it off.
   */
  localized?: boolean;
}

const {
  title,
  description,
  ogImage = site.ogImage,
  noindex = false,
  localized = false,
} = Astro.props;

const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = useTranslations(locale);
const ogLocale = locale === 'es' ? 'es_ES' : 'en_US';

const resolvedDescription =
  description ?? (localized ? t('seo.homeDescription') : site.description);
const pageTitle = title
  ? `${title} — ${site.shortName}`
  : localized
    ? t('seo.homeTitle')
    : `${site.name} — ${site.role}`;

const canonical = new URL(Astro.url.pathname, site.url).href;
// On Spanish pages that fall back to the site-default card, use its localized
// variant; explicit per-page OG paths (project cards) are left untouched.
const resolvedOgImage =
  ogImage === site.ogImage && locale === 'es' ? '/og/es/default.png' : ogImage;
const ogImageUrl = new URL(resolvedOgImage, site.url).href;
const altEn = new URL(localizedPath(Astro.url.pathname, 'en'), site.url).href;
const altEs = new URL(localizedPath(Astro.url.pathname, 'es'), site.url).href;

// First-visit language detection (English pages only). Runs before paint: if the
// visitor has no explicit `lang` cookie and their browser prefers Spanish,
// redirect to the /es equivalent. An explicit choice (set by the toggle) wins.
const detectScript = `(function(){if(/^\\/es(\\/|$)/.test(location.pathname))return;var m=document.cookie.match(/(?:^|;\\s*)lang=(en|es)/);var es=m?m[1]==='es':/^es\\b/i.test(navigator.language||'');if(es){location.replace('/es'+location.pathname+location.search+location.hash);}})();`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {
      /* First-visit language detection. Runs before paint on English
        (unprefixed) pages only: if the visitor has no explicit `lang` cookie
        and their browser prefers Spanish, redirect to the /es equivalent. An
        explicit choice (cookie, set by the toggle) always wins. */
      localized && <script is:inline set:html={detectScript} />
    }
    {
      /* Set `.js` synchronously before first paint so scroll-reveal's hidden
        initial state applies only when JS is available (no-JS = visible). */
    }
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#030014" />

    <title>{pageTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <meta name="author" content={site.name} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    {
      localized && (
        <>
          <link rel="alternate" hreflang="en" href={altEn} />
          <link rel="alternate" hreflang="es" href={altEs} />
          <link rel="alternate" hreflang="x-default" href={altEn} />
        </>
      )
    }

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <!-- Per-page <head> extras (e.g. page-specific JSON-LD) -->
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />

    {
      /* Cloudflare Web Analytics — production-only, and only when a token is
        configured (src/data/site.ts). Cookieless; no consent banner needed. */
      site.analyticsToken && import.meta.env.PROD && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: site.analyticsToken })}
        />
      )
    }
    <style>
      .skip-link {
        position: absolute;
        top: -100%;
        left: var(--spacing-16);
        z-index: 100;
        padding: var(--spacing-8) var(--spacing-16);
        background-color: var(--color-deep-indigo);
        color: var(--color-lilac-white);
        border-radius: var(--radius-md);
        box-shadow: var(--glass-rim-strong);
      }
      .skip-link:focus {
        top: var(--spacing-16);
      }
    </style>
    <script>
      // Site-wide motion, framework-free (bundled + deferred by Astro).
      // Everything pointer/scroll-driven is gated on `pointer: fine` and
      // reduced-motion; CSS keyframes (shimmer, twinkle) are frozen at the
      // source by the global reduced-motion block.
      const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
      const fine = matchMedia('(pointer: fine)').matches;

      // Scroll-reveal — fade + rise as elements enter the viewport.
      const reveals = document.querySelectorAll<HTMLElement>('[data-reveal]');
      if (reduce) {
        reveals.forEach((el) => el.classList.add('is-revealed'));
      } else {
        const revealIO = new IntersectionObserver(
          (entries, obs) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-revealed');
                obs.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.12 },
        );
        reveals.forEach((el) => revealIO.observe(el));
      }

      // Pause star-field twinkle while off-screen (cheap; runs regardless of
      // reduced-motion since the animation may simply be frozen).
      const fields = document.querySelectorAll<HTMLElement>('.starfield');
      if (fields.length) {
        const pauseIO = new IntersectionObserver((entries) => {
          for (const entry of entries) {
            entry.target.classList.toggle('is-paused', !entry.isIntersecting);
          }
        });
        fields.forEach((el) => pauseIO.observe(el));
      }

      if (fine && !reduce) {
        // Magnetic CTAs — translate toward the pointer, spring back on leave.
        const MAGNET = 0.3;
        document.querySelectorAll<HTMLElement>('[data-magnetic]').forEach((el) => {
          el.addEventListener('pointermove', (e) => {
            const r = el.getBoundingClientRect();
            const dx = e.clientX - (r.left + r.width / 2);
            const dy = e.clientY - (r.top + r.height / 2);
            el.style.transform = `translate(${dx * MAGNET}px, ${dy * MAGNET}px)`;
          });
          el.addEventListener('pointerleave', () => {
            el.style.transform = '';
          });
        });

        // Card tilt — rotateX/Y from pointer position via CSS custom props.
        const TILT = 5;
        document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((el) => {
          el.addEventListener('pointermove', (e) => {
            const r = el.getBoundingClientRect();
            const px = (e.clientX - r.left) / r.width - 0.5;
            const py = (e.clientY - r.top) / r.height - 0.5;
            el.style.setProperty('--ry', `${(px * TILT).toFixed(2)}deg`);
            el.style.setProperty('--rx', `${(-py * TILT).toFixed(2)}deg`);
          });
          el.addEventListener('pointerleave', () => {
            el.style.setProperty('--rx', '0deg');
            el.style.setProperty('--ry', '0deg');
          });
        });
      }
    </script>
  </body>
</html>

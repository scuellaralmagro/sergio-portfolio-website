---
/**
 * Expertise — capabilities as a constellation node graph. Placeholder shell
 * (Phase 2); the static graph lands in Phase 3, interactivity in Phase 5.
 */
import Section from './Section.astro';
---

<Section
  id="expertise"
  eyebrow="Expertise"
  eyebrowIcon="network"
  title="Capabilities, mapped like a constellation"
  subtitle="Orchestration · Retrieval · Engineering · Automation & Ops."
>
  <p class="placeholder glass">Capability constellation — Phase 3 (static) / Phase 5 (interactive).</p>
</Section>

<style>
  .placeholder {
    display: grid;
    place-items: center;
    min-height: 220px;
    padding: var(--spacing-24);
    color: var(--color-fog);
    font-size: var(--text-body-sm);
    text-align: center;
  }
</style>

---
/**
 * Expertise — capabilities as four glass cards, one per area, each with its
 * skills as chips (flagship tools highlighted). Plain, scannable content at
 * every breakpoint. Data from src/data/content.ts.
 */
import Section from './Section.astro';
import CapabilityCard from '../primitives/CapabilityCard.astro';
import { expertise } from '../../data/content';
import { useTranslations, type Locale } from '../../i18n/utils';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = useTranslations(locale);
const clusters = expertise[locale];
---

<Section
  id="expertise"
  eyebrow={t('expertise.eyebrow')}
  eyebrowIcon="network"
  title={t('expertise.title')}
  subtitle={t('expertise.subtitle')}
>
  <ul class="cap-grid">
    {
      clusters.map((cluster) => (
        <CapabilityCard
          name={cluster.name}
          icon={cluster.icon}
          skills={cluster.skills}
          flagships={cluster.flagships}
        />
      ))
    }
  </ul>
</Section>

<style>
  .cap-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-24);
  }

  @media (min-width: 768px) {
    .cap-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Six cards tile into an even 3x2 on wide screens. */
  @media (min-width: 1080px) {
    .cap-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

---
/**
 * Expertise — capabilities mapped as a constellation: four hubs (clusters), each
 * with its skills as "stars". The Constellation island carries the visual; the
 * SVG is decorative (aria-hidden), so the .sr-only list below is the accessible
 * text alternative and the no-JS fallback. Data from src/data/content.ts.
 */
import Section from './Section.astro';
import Card from '../primitives/Card.astro';
import Constellation from '../islands/Constellation.tsx';
import { expertise } from '../../data/content';
---

<Section
  id="expertise"
  eyebrow="Expertise"
  eyebrowIcon="network"
  title="Capabilities, mapped like a constellation"
  subtitle="Agents are stars; orchestration is the lines between them. Four clusters define how I build."
>
  <Card strong class="panel">
    <Constellation client:visible clusters={expertise} />
  </Card>

  <ul class="sr-only">
    {
      expertise.map((cluster) => (
        <li>
          {cluster.name}: {cluster.skills.join(', ')}.
        </li>
      ))
    }
  </ul>
</Section>

<style>
  .panel {
    padding: var(--spacing-32);
    width: 100%;
  }
</style>

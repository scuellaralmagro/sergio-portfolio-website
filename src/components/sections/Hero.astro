---
/**
 * Hero — the agentic hook. Full-height, with the living constellation as the
 * signature visual: badge, gradient headline, sub, and dual CTA centered over
 * the drifting star-graph. (The Kynetix agent diagram lives in AI Showcase and
 * the case study — no need to duplicate it here.)
 */
import ConstellationField from '../primitives/ConstellationField.astro';
import Button from '../primitives/Button.astro';
import Badge from '../primitives/Badge.astro';
import { site } from '../../data/site';
---

<section id="hero" class="hero">
  <ConstellationField class="hero-stars" />
  <div class="hero-copy">
    <span data-reveal>
      <Badge icon="sparkle">{site.role}</Badge>
    </span>
    <h1 class="headline" data-reveal style="--reveal-delay: 80ms">
      I orchestrate AI agents into<br />
      <span class="text-cosmic">systems that ship.</span>
    </h1>
    <p class="sub" data-reveal style="--reveal-delay: 160ms">
      Agentic systems, LangGraph orchestration, and RAG architectures — designed, built, and
      deployed in production.
    </p>
    <div class="cta-row" data-reveal style="--reveal-delay: 240ms">
      <Button href="#projects" data-magnetic>View my work</Button>
      <Button variant="ghost" href="#contact">Get in touch</Button>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    /* `svh` (small viewport height) is stable as mobile browsers collapse their
       toolbar on scroll; `dvh` tracks the toolbar frame-by-frame, which forced
       the ConstellationField canvas to resize+reseed every frame and stuttered
       the scroll. `vh` is the fallback for browsers without `svh`. */
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-108) var(--spacing-24) var(--spacing-72);
    overflow: hidden;
  }

  .hero-stars {
    /* ConstellationField is absolutely positioned within its relative parent. */
    z-index: 0;
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-24);
    width: 100%;
    max-width: 68ch;
    text-align: center;
  }

  .headline {
    font-size: var(--text-heading);
    line-height: var(--leading-heading);
    letter-spacing: var(--tracking-heading);
    max-width: 22ch;
  }

  .sub {
    margin: 0;
    max-width: 60ch;
    color: var(--color-ash);
    font-size: var(--text-body-lg);
    line-height: var(--leading-body-lg);
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-16);
    margin-top: var(--spacing-8);
  }

  @media (min-width: 768px) {
    .headline {
      font-size: var(--text-display);
      line-height: var(--leading-display);
      letter-spacing: var(--tracking-display);
    }
  }
</style>

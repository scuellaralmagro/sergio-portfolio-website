---
/**
 * AIShowcase — "How I build agentic systems". Placeholder shell (Phase 2);
 * the animated LangGraph/RAG architecture diagrams land in Phase 5.
 */
import Section from './Section.astro';
---

<Section
  id="ai-showcase"
  eyebrow="AI Showcase"
  eyebrowIcon="workflow"
  title="How I build agentic systems"
  subtitle="Animated, annotated walkthroughs of the real orchestration and retrieval pipelines I ship."
>
  <p class="placeholder glass">Animated architecture diagrams — Phase 5.</p>
</Section>

<style>
  .placeholder {
    display: grid;
    place-items: center;
    min-height: 260px;
    padding: var(--spacing-24);
    color: var(--color-fog);
    font-size: var(--text-body-sm);
    text-align: center;
  }
</style>

---
/**
 * AIShowcase — "How I build agentic systems". Two animated, annotated diagrams
 * of the real architectures behind Kynetix and the RAG support work:
 *  1. a LangGraph multi-agent orchestration graph
 *  2. a RAG retrieval pipeline
 * Diagrams are ArchDiagram islands (client:visible); each sits in a rim-lit
 * glass panel with a text caption that doubles as the accessible description.
 */
import Section from './Section.astro';
import Card from '../primitives/Card.astro';
import ArchDiagram from '../islands/ArchDiagram.tsx';
import {
  orchestrationNodes,
  orchestrationEdges,
  ragNodes,
  ragEdges,
} from '../../data/diagrams';
---

<Section
  id="ai-showcase"
  eyebrow="AI Showcase"
  eyebrowIcon="workflow"
  title="How I build agentic systems"
  subtitle="The real architectures behind my work — agents are stars, orchestration is the lines between them."
>
  <p class="diagrams-source">
    Both are the real architecture behind <a href="/projects/kynetix">Kynetix</a> — my
    full-stack AI training &amp; nutrition coach.
  </p>

  <div class="diagrams">
    <figure class="diagram">
      <h3 class="diagram-title">Multi-agent orchestration</h3>
      <Card strong class="panel">
        <ArchDiagram
          client:visible
          nodes={orchestrationNodes}
          edges={orchestrationEdges}
          viewWidth={830}
          viewHeight={440}
        />
      </Card>
      <figcaption>
        A LangGraph supervisor classifies each message and routes it to one of six specialists
        — single-workout or full-week programming, profile updates, the nutrition sub-graph,
        post-workout analysis, or general chat. Programming grounds plans in a pgvector RAG
        store and deterministic services (1RM, fatigue, TDEE); analysis reads the relational
        workout history; nutrition commits via a human-in-the-loop confirm. Conversation state
        persists through a Postgres checkpointer and replies stream token-by-token over SSE.
      </figcaption>
    </figure>

    <figure class="diagram">
      <h3 class="diagram-title">RAG retrieval pipeline</h3>
      <Card strong class="panel">
        <ArchDiagram
          client:visible
          nodes={ragNodes}
          edges={ragEdges}
          viewWidth={1000}
          viewHeight={158}
        />
      </Card>
      <figcaption>
        Reference knowledge (kinesiology, nutrition) is embedded and stored once; at query
        time the question is embedded, matched against a pgvector HNSW index, and the top-k
        chunks ground the model's answer — no ungrounded guessing.
      </figcaption>
    </figure>
  </div>
</Section>

<style>
  .diagrams {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-48);
    width: 100%;
  }
  .diagram {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-16);
  }
  .diagram-title {
    font-size: var(--text-body-lg);
    color: var(--color-lilac-white);
  }
  .panel {
    padding: var(--spacing-32);
  }
  figcaption {
    color: var(--color-fog);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body-sm);
  }
  .diagrams-source {
    margin: 0 0 var(--spacing-32);
    color: var(--color-ash);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body-sm);
  }
</style>

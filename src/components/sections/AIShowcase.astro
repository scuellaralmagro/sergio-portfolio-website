---
/**
 * AIShowcase — "How I build agentic systems". Two animated, annotated diagrams
 * of the real architectures behind Kynetix and the RAG support work:
 *  1. a LangGraph multi-agent orchestration graph
 *  2. a RAG retrieval pipeline
 * Diagrams are ArchDiagram islands hydrated `client:idle` — the heavy
 * framer-motion chunk is parsed during post-load idle time rather than
 * mid-scroll as the section enters view, which removes a scroll stutter on
 * mobile. The draw-on animation still fires on scroll via framer's whileInView.
 * Each sits in a rim-lit glass panel with a caption that doubles as the
 * accessible description (the SVG itself is aria-hidden).
 */
import Section from './Section.astro';
import Card from '../primitives/Card.astro';
import ArchDiagram from '../islands/ArchDiagram.tsx';
import {
  orchestrationNodes,
  orchestrationEdges,
  ragNodes,
  ragEdges,
} from '../../data/diagrams';
import { useTranslations, localizedPath, type Locale } from '../../i18n/utils';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = useTranslations(locale);
---

<Section
  id="ai-showcase"
  eyebrow={t('showcase.eyebrow')}
  eyebrowIcon="workflow"
  title={t('showcase.title')}
  subtitle={t('showcase.subtitle')}
>
  <p class="diagrams-source">
    {t('showcase.sourcePre')}<a href={localizedPath('/projects/kynetix', locale)}
      >{t('showcase.sourceLink')}</a
    >{t('showcase.sourcePost')}
  </p>

  <div class="diagrams">
    <figure class="diagram">
      <h3 class="diagram-title">{t('showcase.diagram1Title')}</h3>
      <Card strong class="panel">
        <ArchDiagram
          client:idle
          nodes={orchestrationNodes}
          edges={orchestrationEdges}
          viewWidth={830}
          viewHeight={440}
        />
      </Card>
      <figcaption>{t('showcase.diagram1Caption')}</figcaption>
    </figure>

    <figure class="diagram">
      <h3 class="diagram-title">{t('showcase.diagram2Title')}</h3>
      <Card strong class="panel">
        <ArchDiagram
          client:idle
          nodes={ragNodes}
          edges={ragEdges}
          viewWidth={1000}
          viewHeight={158}
        />
      </Card>
      <figcaption>{t('showcase.diagram2Caption')}</figcaption>
    </figure>
  </div>
</Section>

<style>
  .diagrams {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-48);
    width: 100%;
  }
  .diagram {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-16);
  }
  .diagram-title {
    font-size: var(--text-body-lg);
    color: var(--color-lilac-white);
  }
  .panel {
    padding: var(--spacing-32);
  }
  figcaption {
    color: var(--color-fog);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body-sm);
  }
  .diagrams-source {
    margin: 0 0 var(--spacing-32);
    color: var(--color-ash);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body-sm);
  }
</style>

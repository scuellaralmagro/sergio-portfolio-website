---
/**
 * AskPortfolio — the live "proof of self" demo. A React island streams grounded
 * answers about Sergio from the api.sergiocuellar.dev RAG endpoint. The island is
 * server-rendered (client:visible), so its hero + email CTA are the no-JS baseline.
 */
import Section from './Section.astro';
import Card from '../primitives/Card.astro';
import AIConsole from '../islands/AIConsole.tsx';
import { useTranslations, type Locale } from '../../i18n/utils';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = useTranslations(locale);
---

<Section
  id="ask-portfolio"
  eyebrow={t('ask.eyebrow')}
  eyebrowIcon="sparkle"
  title={t('ask.title')}
  subtitle={t('ask.subtitle')}
>
  <Card strong padding="lg" class="ask-card">
    <AIConsole client:visible lang={locale} />
  </Card>
</Section>

<style>
  .ask-card {
    width: 100%;
  }

  .ask-card :global(.ai-console) {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-20);
    min-height: 460px;
  }

  /* Stage holds either the hero or the transcript; both fade-swap here. */
  .ask-card :global(.console-stage) {
    position: relative;
    flex: 1;
    display: flex;
  }
  .ask-card :global(.stage-pane) {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  /* --- Orb (outer = layout-morph box; core = gradient + breathing) ---- */
  .ask-card :global(.orb) {
    display: inline-flex;
    border-radius: 50%;
    flex: 0 0 auto;
  }
  .ask-card :global(.orb-core) {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, var(--color-cosmic-gradient), var(--color-iris));
  }
  .ask-card :global(.orb-hero .orb-core) {
    box-shadow: 0 0 34px color-mix(in oklab, var(--color-iris) 55%, transparent);
  }
  .ask-card :global(.orb-avatar .orb-core) {
    box-shadow: 0 0 10px color-mix(in oklab, var(--color-iris) 45%, transparent);
  }
  .ask-card :global(.orb-active .orb-core) {
    box-shadow: 0 0 18px color-mix(in oklab, var(--color-lavender-accent) 65%, transparent);
  }

  /* --- Hero (idle) ---------------------------------------------------- */
  .ask-card :global(.hero) {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: var(--spacing-16);
    padding: var(--spacing-24) 0;
  }
  .ask-card :global(.hero-label) {
    margin: 0;
    font-size: var(--text-caption);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ash);
  }
  .ask-card :global(.starters) {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-8);
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 480px;
  }
  .ask-card :global(.starter) {
    padding: var(--spacing-8) var(--spacing-16);
    background-color: color-mix(in oklab, var(--color-lavender-accent) 12%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-lavender-accent) 40%, transparent);
    border-radius: var(--radius-full);
    color: var(--color-lilac-white);
    font-size: var(--text-body-sm);
    cursor: pointer;
    transition: background-color 0.18s ease;
  }
  .ask-card :global(.starter:hover) {
    background-color: color-mix(in oklab, var(--color-lavender-accent) 22%, transparent);
  }
  .ask-card :global(.hero-contact) {
    margin: 0;
    font-size: var(--text-caption);
    color: var(--color-fog);
  }
  .ask-card :global(.hero-contact a) {
    color: var(--color-lavender-accent);
  }

  /* --- Transcript (active) ------------------------------------------- */
  .ask-card :global(.transcript) {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-16);
    list-style: none;
    margin: 0;
    /* Inline padding leaves room for the avatar orb's glow — the vertical scroll
       (overflow-y) forces overflow-x to clip, so the glow needs breathing room. */
    padding: var(--spacing-8) var(--spacing-20);
    max-height: 460px;
    overflow-y: auto;
  }
  .ask-card :global(.turn) {
    display: flex;
    gap: var(--spacing-8);
    max-width: min(80%, 60ch);
  }
  .ask-card :global(.turn-user) {
    align-self: flex-end;
  }
  .ask-card :global(.turn-assistant) {
    align-self: flex-start;
  }
  .ask-card :global(.avatar) {
    flex: 0 0 auto;
    padding-top: 2px;
  }
  .ask-card :global(.bubble) {
    margin: 0;
    padding: var(--spacing-12) var(--spacing-16);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body-sm);
    color: var(--color-lilac-white);
    white-space: pre-wrap;
    border-radius: var(--radius-2xl);
  }
  .ask-card :global(.turn-assistant .bubble) {
    background-color: color-mix(in oklab, var(--color-lilac-white) 4%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-lilac-white) 10%, transparent);
    border-bottom-left-radius: var(--radius-md);
  }
  .ask-card :global(.turn-user .bubble) {
    background-color: color-mix(in oklab, var(--color-iris) 22%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-iris) 40%, transparent);
    border-bottom-right-radius: var(--radius-md);
  }
  .ask-card :global(.caret) {
    display: inline-block;
    width: 2px;
    height: 1em;
    margin-left: 2px;
    vertical-align: text-bottom;
    background-color: var(--color-lavender-accent);
    animation: ai-blink 1s steps(2, start) infinite;
  }

  /* --- Sources + notice ---------------------------------------------- */
  .ask-card :global(.sources) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-8);
  }
  .ask-card :global(.sources-label) {
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-ash);
  }
  .ask-card :global(.source-chip) {
    padding: 2px var(--spacing-8);
    border-radius: var(--radius-full);
    background-color: color-mix(in oklab, var(--color-iris) 16%, transparent);
    color: var(--color-lilac-white);
    font-size: var(--text-caption);
  }
  .ask-card :global(.notice) {
    align-self: flex-start;
    max-width: min(80%, 60ch);
    padding: var(--spacing-12) var(--spacing-16);
    border-radius: var(--radius-2xl);
    border: 1px solid color-mix(in oklab, var(--color-lavender-accent) 30%, transparent);
    background-color: color-mix(in oklab, var(--color-deep-indigo) 40%, transparent);
    color: var(--color-ash);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body-sm);
  }

  /* --- Composer ------------------------------------------------------- */
  .ask-card :global(.composer-row) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-8);
  }
  .ask-card :global(.composer) {
    display: flex;
    align-items: center;
    gap: var(--spacing-8);
    width: 100%;
    max-width: 560px;
    background-color: color-mix(in oklab, var(--color-lilac-white) 4%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-lavender-accent) 50%, transparent);
    border-radius: var(--radius-full);
    padding: var(--spacing-8) var(--spacing-8) var(--spacing-8) var(--spacing-20);
    transition: max-width 0.3s ease;
  }
  /* Once the conversation starts, the composer widens to the full card width. */
  .ask-card :global(.ai-console.started .composer) {
    max-width: 100%;
  }
  @media (prefers-reduced-motion: reduce) {
    .ask-card :global(.composer) {
      transition: none;
    }
  }
  .ask-card :global(.input) {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: 0;
    color: var(--color-lilac-white);
    font-size: var(--text-body-sm);
  }
  .ask-card :global(.input:focus-visible) {
    outline: none;
  }
  .ask-card :global(.composer:focus-within) {
    border-color: var(--color-lavender-accent);
  }
  .ask-card :global(.send) {
    flex: 0 0 auto;
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border: 0;
    border-radius: var(--radius-full);
    background-color: var(--color-iris);
    color: var(--color-pearl);
    font-size: var(--text-body);
    cursor: pointer;
  }
  .ask-card :global(.send:disabled) {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .ask-card :global(.reset) {
    background: none;
    border: 0;
    color: var(--color-fog);
    font-size: var(--text-caption);
    cursor: pointer;
  }
  .ask-card :global(.reset:hover) {
    color: var(--color-ash);
  }

  .ask-card :global(.turnstile-host) {
    display: flex;
    justify-content: center;
  }
  .ask-card :global(.sr-only) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @keyframes ai-blink {
    to {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ask-card :global(.caret) {
      animation: none;
    }
  }
</style>

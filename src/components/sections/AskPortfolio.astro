---
/**
 * AskPortfolio — the live "proof of self" demo. A React island streams grounded
 * answers about Sergio from the api.sergiocuellar.dev RAG endpoint. The island is
 * server-rendered (client:visible), so its intro + email CTA are the no-JS baseline.
 */
import Section from './Section.astro';
import Card from '../primitives/Card.astro';
import AIConsole from '../islands/AIConsole.tsx';
---

<Section
  id="ask-portfolio"
  eyebrow="Ask my portfolio"
  eyebrowIcon="sparkle"
  title="Ask my portfolio"
  subtitle="A live RAG assistant, grounded in my real experience — the architecture above, working."
>
  <Card strong padding="lg" class="ask-card">
    <AIConsole client:visible />
  </Card>
</Section>

<style>
  .ask-card {
    width: 100%;
    max-width: 720px;
    margin-inline: auto;
  }

  /* Console styles are global (:global) because the transcript is rendered by the
     React island, whose DOM is outside this component's scoped-style reach. */
  .ask-card :global(.ai-console) {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-20);
  }
  .ask-card :global(.intro-lead),
  .ask-card :global(.banner) {
    margin: 0;
    color: var(--color-fog);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body-sm);
  }
  .ask-card :global(.intro-lead a) {
    color: var(--color-lavender-accent);
  }
  .ask-card :global(.starters) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .ask-card :global(.starter) {
    padding: var(--spacing-8) var(--spacing-12);
    background-color: color-mix(in oklab, var(--color-lavender-accent) 10%, transparent);
    border: 0;
    border-radius: var(--radius-full);
    color: var(--color-lilac-white);
    font-size: var(--text-body-sm);
    cursor: pointer;
    transition: background-color 0.18s ease;
  }
  .ask-card :global(.starter:hover) {
    background-color: color-mix(in oklab, var(--color-lavender-accent) 18%, transparent);
  }
  .ask-card :global(.transcript) {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-16);
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 420px;
    overflow-y: auto;
  }
  .ask-card :global(.turn) {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }
  .ask-card :global(.role) {
    font-size: var(--text-body-xs, 12px);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-ash);
  }
  .ask-card :global(.bubble) {
    margin: 0;
    color: var(--color-lilac-white);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body-sm);
    white-space: pre-wrap;
  }
  .ask-card :global(.turn-user .bubble) {
    color: var(--color-fog);
  }
  .ask-card :global(.caret) {
    display: inline-block;
    width: 2px;
    height: 1em;
    margin-left: 2px;
    vertical-align: text-bottom;
    background-color: var(--color-lavender-accent);
    animation: ai-blink 1s steps(2, start) infinite;
  }
  .ask-card :global(.sources) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-8);
  }
  .ask-card :global(.sources-label) {
    font-size: var(--text-body-xs, 12px);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-ash);
  }
  .ask-card :global(.source-chip) {
    padding: 2px var(--spacing-8);
    border-radius: var(--radius-full);
    background-color: color-mix(in oklab, var(--color-iris) 14%, transparent);
    color: var(--color-lilac-white);
    font-size: var(--text-body-xs, 12px);
  }
  .ask-card :global(.composer) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
  }
  .ask-card :global(.input) {
    flex: 1 1 200px;
    padding: var(--spacing-12) var(--spacing-16);
    background-color: color-mix(in oklab, var(--color-midnight-surface) 60%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-lavender-accent) 24%, transparent);
    border-radius: var(--radius-md);
    color: var(--color-lilac-white);
    font-size: var(--text-body-sm);
  }
  .ask-card :global(.input:focus-visible) {
    outline: 2px solid var(--color-lavender-accent);
    outline-offset: 1px;
  }
  .ask-card :global(.send),
  .ask-card :global(.clear) {
    padding: var(--spacing-12) var(--spacing-20);
    border: 0;
    border-radius: var(--radius-md);
    font-size: var(--text-body-sm);
    cursor: pointer;
  }
  .ask-card :global(.send) {
    background-color: var(--color-iris);
    color: var(--color-lilac-white);
  }
  .ask-card :global(.send:disabled) {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .ask-card :global(.clear) {
    background-color: transparent;
    color: var(--color-ash);
  }
  /* Do NOT display:none this — with appearance:'interaction-only' the widget is
     already invisible for visitors who pass silently, and it must be able to
     render an interactive challenge (centered) for those who don't. */
  .ask-card :global(.turnstile-host) {
    display: flex;
    justify-content: center;
  }
  .ask-card :global(.sr-only) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @keyframes ai-blink {
    to {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ask-card :global(.caret) {
      animation: none;
    }
  }
</style>

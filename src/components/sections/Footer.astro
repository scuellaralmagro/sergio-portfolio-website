---
/**
 * Footer — closing band. Monogram + wordmark, in-page nav, socials, and a
 * colophon, over a subtle living constellation. Mirrors the NavPill link set.
 */
import ConstellationField from '../primitives/ConstellationField.astro';
import Icon from '../primitives/Icon.astro';
import { site, socials } from '../../data/site';
import { useTranslations, localizedPath, type Locale } from '../../i18n/utils';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = useTranslations(locale);
const home = localizedPath('/', locale).replace(/\/$/, '');

const navLinks = [
  { label: t('nav.about'), href: `${home}/#about` },
  { label: t('nav.expertise'), href: `${home}/#expertise` },
  { label: t('nav.projects'), href: `${home}/#projects` },
  { label: t('nav.experience'), href: `${home}/#experience` },
  { label: t('contact.eyebrow'), href: `${home}/#contact` },
];

const socialLinks = [
  { label: 'GitHub', href: socials.github, icon: 'github' as const },
  { label: 'LinkedIn', href: socials.linkedin, icon: 'linkedin' as const },
  { label: 'Email', href: socials.email, icon: 'mail' as const },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <ConstellationField class="footer-stars" density={0.7} />
  <div class="footer-inner">
    <div class="top">
      <a class="brand" href={`${home}/#hero`} aria-label={`${site.shortName} — ${t('footer.backToTop')}`}>
        <span class="monogram" aria-hidden="true">{site.monogram}</span>
        <span class="brand-name">{site.shortName}</span>
      </a>

      <nav class="footer-nav" aria-label="Footer">
        <ul>
          {navLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <ul class="socials">
        {
          socialLinks.map((s) => (
            <li>
              <a
                href={s.href}
                aria-label={s.label}
                {...(s.icon === 'mail' ? {} : { target: '_blank', rel: 'noopener noreferrer' })}
              >
                <Icon name={s.icon} size={18} title={s.label} />
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <hr class="aurora-divider" />

    <div class="bottom">
      <p class="colophon">
        © {year} {site.name} · {site.role} · {t('footer.colophonSuffix')}
      </p>
      <ul class="legal-links">
        <li>
          <a href={localizedPath('/privacy', locale)}>{t('footer.privacy')}</a>
        </li>
        <li>
          <a href={localizedPath('/legal', locale)}>{t('footer.legal')}</a>
        </li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    overflow: hidden;
    background-color: var(--color-midnight-surface);
    box-shadow: var(--glass-rim);
  }

  .footer-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin-inline: auto;
    padding: var(--spacing-64) var(--spacing-24) var(--spacing-48);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-32);
  }

  .top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-24);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-12);
    color: var(--color-lilac-white);
    text-decoration: none;
    font-family: var(--font-dm-sans);
    font-weight: 500;
  }
  .monogram {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-iris);
    box-shadow: var(--glass-badge);
    font-size: var(--text-body-sm);
    color: var(--color-lavender-accent);
  }

  .footer-nav ul,
  .socials {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-20);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer-nav a {
    color: var(--color-ash);
    text-decoration: none;
    font-size: var(--text-body-sm);
    transition: color 0.18s ease;
  }
  .footer-nav a:hover {
    color: var(--color-lilac-white);
  }

  .socials a {
    display: inline-flex;
    color: var(--color-ash);
    transition: color 0.18s ease;
  }
  .socials a:hover {
    color: var(--color-lavender-accent);
  }

  .bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-16);
  }
  .colophon {
    margin: 0;
    color: var(--color-fog);
    font-size: var(--text-caption);
  }
  .legal-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-16);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .legal-links a {
    color: var(--color-fog);
    text-decoration: none;
    font-size: var(--text-caption);
    transition: color 0.18s ease;
  }
  .legal-links a:hover {
    color: var(--color-lilac-white);
  }

  @media (max-width: 640px) {
    .top {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

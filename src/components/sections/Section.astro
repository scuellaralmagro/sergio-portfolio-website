---
/**
 * Section — shared layout wrapper for every home-page section.
 * Owns the anchor id (scroll-spy + in-page nav targets), the section
 * vertical rhythm (96–120px), the 1200px container, and an optional
 * SectionHeader. Phase 3 fills each section body through the default slot.
 */
import SectionHeader from '../primitives/SectionHeader.astro';
import type { IconName } from '../primitives/Icon.astro';

interface Props {
  /** Anchor id — must match the corresponding NavPill link / IA (§4.1). */
  id: string;
  eyebrow?: string;
  eyebrowIcon?: IconName;
  title?: string;
  subtitle?: string;
  align?: 'center' | 'left';
  class?: string;
}

const {
  id,
  eyebrow,
  eyebrowIcon = 'sparkle',
  title,
  subtitle,
  align = 'center',
  class: className,
}: Props = Astro.props;
---

<section id={id} class:list={['section', className]}>
  <div class:list={['container', `align-${align}`]}>
    {
      title && (
        <SectionHeader
          eyebrow={eyebrow}
          eyebrowIcon={eyebrowIcon}
          title={title}
          subtitle={subtitle}
          align={align}
        />
      )
    }
    <div class="section-body">
      <slot />
    </div>
  </div>
</section>

<style>
  .section {
    /* Section rhythm: 72px on mobile → 108px on larger viewports (§6.4). */
    padding-block: var(--spacing-72);
    scroll-margin-top: var(--spacing-72);
  }

  .container {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--spacing-24);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-48);
  }
  .align-center {
    align-items: center;
  }
  .align-left {
    align-items: stretch;
  }

  .section-body {
    width: 100%;
  }

  @media (min-width: 768px) {
    .section {
      padding-block: var(--spacing-108);
    }
  }
</style>

---
/**
 * About — narrative + rim-lit portrait. Two short paragraphs (ULTRAPLAN §5):
 * what I build + the philosophy, then the full-stack/data foundation.
 *
 * The section header lives inside the left column (not via Section's own
 * header slot) so the portrait can span the full height of the column —
 * from the title down to the end of the text — rather than only the body.
 *
 * Portrait: optimized at build time via astro:assets (responsive AVIF/WebP,
 * intrinsic width/height to avoid CLS). Swap the import to change the photo;
 * set `portrait` to null to fall back to the monogram placeholder.
 */
import { Picture } from 'astro:assets';
import Section from './Section.astro';
import SectionHeader from '../primitives/SectionHeader.astro';
import { site } from '../../data/site';
import portraitImg from '../../assets/portrait.jpg';

const portrait: ImageMetadata | null = portraitImg;
---

<Section id="about" align="left">
  <div class="about-grid">
    <div class="about-main">
      <SectionHeader
        eyebrow="About"
        title="Who I am"
        subtitle="An AI/LLM engineer who turns manual processes into scalable agentic architectures."
        align="left"
      />
      <div class="prose">
        <p>
          I build the systems that make AI <em>act</em> — multi-agent orchestrations and
          retrieval pipelines that move from prototype to production. My focus is agentic
          design with LangChain and LangGraph, RAG over Postgres and pgvector, and the
          prompt engineering that makes all of it reliable enough to put in front of real
          users over channels like WhatsApp.
        </p>
        <p>
          Underneath the AI work is a full-stack and data foundation — Python, TypeScript,
          Node, and React, plus the database and automation tooling to wire services
          together end-to-end. It means I can take an idea from architecture through
          deployment myself, rather than stopping at the demo.
        </p>
      </div>
    </div>

    <figure class="portrait">
      {
        portrait ? (
          <Picture
            src={portrait}
            formats={['avif', 'webp']}
            widths={[360, 720]}
            sizes="(max-width: 400px) 90vw, 360px"
            alt={`${site.name} — portrait`}
            loading="lazy"
            decoding="async"
          />
        ) : (
          <span class="portrait-placeholder" aria-hidden="true">
            {site.monogram}
          </span>
        )
      }
    </figure>
  </div>
</Section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-48);
    align-items: start;
  }

  .about-main {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-32);
  }

  .prose {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-20);
    max-width: 60ch;
  }
  .prose p {
    margin: 0;
    color: var(--color-ash);
    font-size: var(--text-body-lg);
    line-height: var(--leading-body-lg);
  }
  .prose em {
    font-style: normal;
    color: var(--color-lilac-white);
  }

  .portrait {
    margin: 0;
    aspect-ratio: 4 / 5;
    width: 100%;
    max-width: 360px;
    border-radius: var(--radius-3xl);
    overflow: hidden;
    background-color: var(--color-midnight-surface);
    box-shadow: var(--glass-rim-strong);
    display: grid;
    place-items: center;
  }
  .portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top; /* keep the face when the frame crops */
  }
  .portrait-placeholder {
    font-family: var(--font-aeonikpro);
    font-weight: 500;
    font-size: var(--text-display);
    color: var(--color-lavender-accent);
    opacity: 0.5;
  }

  @media (min-width: 880px) {
    .about-grid {
      grid-template-columns: 1fr 360px;
      align-items: stretch;
    }
    /* Portrait spans the full height of the left column — title to text-end —
       instead of hanging below the shorter body text. */
    .portrait {
      aspect-ratio: auto;
      max-width: none;
      height: 100%;
    }
  }
</style>

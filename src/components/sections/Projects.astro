---
/**
 * Projects — flagship project grid. Reads from the typed `projects` content
 * collection (single source shared with /projects/[slug]); each card links to
 * its case study, with a pointer-driven tilt + hover rim-light (Phase 6).
 */
import Section from './Section.astro';
import Card from '../primitives/Card.astro';
import TextLink from '../primitives/TextLink.astro';
import { getCollection } from 'astro:content';
import { useTranslations, localizedPath, type Locale } from '../../i18n/utils';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = useTranslations(locale);

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .filter((entry) => entry.id.startsWith(`${locale}/`))
  .sort((a, b) => a.data.order - b.data.order);
---

<Section
  id="projects"
  eyebrow={t('projects.eyebrow')}
  eyebrowIcon="layers"
  title={t('projects.title')}
  subtitle={t('projects.subtitle')}
>
  <div class="grid">
    {
      projects.map((entry) => {
        const { title, summary, stack, repo, live, note } = entry.data;
        const slug = entry.id.replace(/^(en|es)\//, '');
        const href = localizedPath(`/projects/${slug}`, locale);
        return (
          <Card class="project" strong as="article" data-tilt>
            <div class="project-body">
              <h3 class="project-title">
                <a href={href}>{title}</a>
              </h3>
              <p class="project-summary">{summary}</p>
              <ul class="stack">
                {stack.map((tech) => (
                  <li class="chip">{tech}</li>
                ))}
              </ul>
            </div>
            <div class="project-foot">
              <TextLink href={href}>Case study</TextLink>
              {repo ? (
                <TextLink href={repo} external>
                  Code
                </TextLink>
              ) : (
                note && <span class="note">{note}</span>
              )}
              {live && (
                <TextLink href={live} external>
                  Live
                </TextLink>
              )}
            </div>
          </Card>
        );
      })
    }
  </div>
</Section>

<style>
  /* Flex-wrap (not grid) so the last row's cards center under the row above:
     five cards render 3 + 2, with the trailing two centred. Cards keep an
     identical width and reflow to 2-up, then 1-up, as the viewport narrows. */
  .grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-16);
    width: 100%;
  }

  .project {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--spacing-20);
    /* Base three-up: one third of the row minus the two gaps (with a 1px
       slack so sub-pixel rounding never forces a premature wrap). min-width
       drives the collapse to 2-up and 1-up on smaller screens. */
    flex: 0 1 calc((100% - 2 * var(--spacing-16)) / 3 - 1px);
    min-width: 280px;
    max-width: 420px;
    /* No height:100% — in a flex row the default align-items:stretch already
       equalises card heights per row; a percentage height would defeat it. */
  }
  .project-body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-12);
  }
  .project-title {
    font-size: var(--text-body-lg);
  }
  .project-title a {
    color: var(--color-lilac-white);
    text-decoration: none;
    transition: color 0.18s ease;
  }
  .project-title a:hover {
    color: var(--color-lavender-accent);
  }
  .project-summary {
    margin: 0;
    color: var(--color-ash);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body-sm);
  }

  .stack {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
  }
  .chip {
    padding: var(--spacing-4) var(--spacing-12);
    border: 1px solid var(--color-iris);
    border-radius: var(--radius-3xl-2);
    color: var(--color-mercury);
    font-size: var(--text-caption);
    line-height: 1.4;
  }

  .project-foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-20);
  }
  .note {
    color: var(--color-fog);
    font-size: var(--text-body-sm);
  }
</style>

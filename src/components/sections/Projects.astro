---
/**
 * Projects — flagship project grid. Reads from the typed `projects` content
 * collection (single source shared with /projects/[slug]); each card links to
 * its case study, with a pointer-driven tilt + hover rim-light (Phase 6).
 */
import Section from './Section.astro';
import Card from '../primitives/Card.astro';
import TextLink from '../primitives/TextLink.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Section
  id="projects"
  eyebrow="Projects"
  eyebrowIcon="layers"
  title="Flagship work"
  subtitle="Selected projects I designed and built — from agentic systems to deep-learning vision and NLP."
>
  <div class="grid">
    {
      projects.map((entry) => {
        const { title, summary, stack, repo, live, note } = entry.data;
        const href = `/projects/${entry.id}`;
        return (
          <Card class="project" strong as="article" data-tilt>
            <div class="project-body">
              <h3 class="project-title">
                <a href={href}>{title}</a>
              </h3>
              <p class="project-summary">{summary}</p>
              <ul class="stack">
                {stack.map((tech) => (
                  <li class="chip">{tech}</li>
                ))}
              </ul>
            </div>
            <div class="project-foot">
              <TextLink href={href}>Case study</TextLink>
              {repo ? (
                <TextLink href={repo} external>
                  Code
                </TextLink>
              ) : (
                note && <span class="note">{note}</span>
              )}
              {live && (
                <TextLink href={live} external>
                  Live
                </TextLink>
              )}
            </div>
          </Card>
        );
      })
    }
  </div>
</Section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-16);
    width: 100%;
  }

  .project {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--spacing-20);
    height: 100%;
  }
  .project-body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-12);
  }
  .project-title {
    font-size: var(--text-body-lg);
  }
  .project-title a {
    color: var(--color-lilac-white);
    text-decoration: none;
    transition: color 0.18s ease;
  }
  .project-title a:hover {
    color: var(--color-lavender-accent);
  }
  .project-summary {
    margin: 0;
    color: var(--color-ash);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body-sm);
  }

  .stack {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
  }
  .chip {
    padding: var(--spacing-4) var(--spacing-12);
    border: 1px solid var(--color-iris);
    border-radius: var(--radius-3xl-2);
    color: var(--color-mercury);
    font-size: var(--text-caption);
    line-height: 1.4;
  }

  .project-foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-20);
  }
  .note {
    color: var(--color-fog);
    font-size: var(--text-body-sm);
  }
</style>

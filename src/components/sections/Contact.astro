---
/**
 * Contact — conversion point. The hero and nav CTA both target #contact, so
 * this ships with working affordances now; résumé download + final copy and
 * polish land in Phase 3.
 */
import Section from './Section.astro';
import Button from '../primitives/Button.astro';
import TextLink from '../primitives/TextLink.astro';
import { site, socials } from '../../data/site';
import { useTranslations, type Locale } from '../../i18n/utils';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = useTranslations(locale);
---

<Section
  id="contact"
  eyebrow={t('contact.eyebrow')}
  eyebrowIcon="mail"
  title={t('contact.title')}
  subtitle={t('contact.subtitle')}
>
  <div class="contact-actions">
    <div class="cta-buttons">
      <Button href={socials.email}>{t('contact.email')}</Button>
      <Button variant="ghost" href={site.resumeUrl} download>{t('contact.resume')}</Button>
    </div>
    <div class="links">
      <TextLink href={socials.github} external>{t('contact.github')}</TextLink>
      <TextLink href={socials.linkedin} external>{t('contact.linkedin')}</TextLink>
    </div>
    <p class="loc">{t('contact.locationPrefix')}{site.location}</p>
  </div>
</Section>

<style>
  .contact-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-20);
    text-align: center;
  }
  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-16);
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-24);
  }
  .loc {
    margin: 0;
    color: var(--color-fog);
    font-size: var(--text-body-sm);
  }
</style>

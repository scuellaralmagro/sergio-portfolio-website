---
/**
 * StarField — decorative constellation backdrop (tiny low-opacity dots on the
 * void canvas). Each star twinkles (opacity pulse) on a deterministic offset;
 * the motion module pauses the whole field while it's off-screen. Purely
 * decorative (aria-hidden).
 *
 * Star data is generated deterministically at build time (seeded PRNG) so SSR
 * output is stable; twinkle is pure CSS, frozen to a static field under
 * reduced-motion (handled globally).
 */
interface Props {
  count?: number;
  class?: string;
}

const { count = 70, class: className } = Astro.props;

let seed = 20260618;
const rand = () => {
  seed = (seed * 1103515245 + 12345) & 0x7fffffff;
  return seed / 0x7fffffff;
};

const stars = Array.from({ length: count }, () => ({
  x: +(rand() * 100).toFixed(2),
  y: +(rand() * 100).toFixed(2),
  size: +(rand() * 1.6 + 0.4).toFixed(2),
  opacity: +(rand() * 0.5 + 0.15).toFixed(2),
  delay: +(rand() * 6).toFixed(2),
  dur: +(rand() * 3 + 3).toFixed(2),
}));
---

<div class:list={['starfield', className]} aria-hidden="true">
  {
    stars.map((star) => (
      <span
        class="star"
        style={`left:${star.x}%;top:${star.y}%;width:${star.size}px;height:${star.size}px;--base:${star.opacity};--tw-delay:${star.delay}s;--tw-dur:${star.dur}s`}
      />
    ))
  }
</div>

<style>
  .starfield {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }
  .star {
    position: absolute;
    border-radius: var(--radius-full);
    background-color: var(--color-lilac-white);
    opacity: var(--base);
    animation: twinkle var(--tw-dur) ease-in-out var(--tw-delay) infinite;
  }
  .starfield.is-paused .star {
    animation-play-state: paused;
  }
  @keyframes twinkle {
    0%,
    100% {
      opacity: var(--base);
    }
    50% {
      opacity: calc(var(--base) * 0.35);
    }
  }
</style>

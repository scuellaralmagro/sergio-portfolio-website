---
/**
 * NavPill — floating, centered pill navigation.
 * Markup is server-rendered; the inline <script> adds scroll-spy (active link),
 * a `data-scrolled` flag, and the mobile dropdown menu — all framework-free,
 * keeping the page's near-zero JS baseline (ULTRAPLAN §9). Below 720px the
 * inline section links collapse into a hamburger-triggered glass dropdown; the
 * desktop pill is unchanged. Transitions freeze to a static pill/panel under
 * reduced-motion (global block).
 */
import Button from './Button.astro';
import { site } from '../../data/site';

// Absolute (root-anchored) so the nav works from sub-pages (e.g. /projects/*)
// as well as the home page.
const links = [
  { label: 'About', href: '/#about' },
  { label: 'Expertise', href: '/#expertise' },
  { label: 'Showcase', href: '/#ai-showcase' },
  { label: 'Ask', href: '/#ask-portfolio' },
  { label: 'Projects', href: '/#projects' },
  { label: 'Experience', href: '/#experience' },
];
---

<nav class="nav-wrap" aria-label="Primary">
  <div class="pill" data-nav-pill>
    <a class="brand" href="/#hero" aria-label={`${site.shortName} — home`}>
      <svg class="brand-mark" width="22" height="22" viewBox="0 0 32 32" aria-hidden="true">
        <g stroke="currentColor" stroke-width="1.1" stroke-linecap="round" opacity="0.7">
          <line x1="9" y1="11" x2="16" y2="7"></line>
          <line x1="16" y1="7" x2="23" y2="13"></line>
          <line x1="23" y1="13" x2="18" y2="22"></line>
          <line x1="18" y1="22" x2="9" y2="11"></line>
        </g>
        <g fill="currentColor">
          <circle cx="9" cy="11" r="1.6"></circle>
          <circle cx="16" cy="7" r="1.9"></circle>
          <circle cx="23" cy="13" r="1.6"></circle>
          <circle cx="18" cy="22" r="1.6"></circle>
        </g>
      </svg>
      <span class="brand-name">{site.shortName}</span>
    </a>

    <ul class="links">
      {
        links.map((link) => (
          <li>
            <a href={link.href} data-nav-link>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="actions">
      <Button class="nav-cta" href="/#contact" size="sm">Get in touch</Button>
      <button
        type="button"
        class="menu-toggle"
        data-menu-toggle
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="bars" aria-hidden="true"></span>
      </button>
    </div>
  </div>

  <div class="menu" id="mobile-menu" data-menu>
    <ul class="menu-links">
      {
        links.map((link) => (
          <li>
            <a href={link.href} data-nav-link data-menu-link>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
    <hr class="aurora-divider" />
    <Button href="/#contact" data-menu-link>Get in touch</Button>
  </div>
</nav>

<style>
  .nav-wrap {
    position: fixed;
    top: var(--spacing-20);
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-12);
    padding-inline: var(--spacing-16);
    pointer-events: none;
  }

  .pill {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: var(--spacing-24);
    height: 56px;
    padding: var(--spacing-8) var(--spacing-12) var(--spacing-8) var(--spacing-20);
    background-color: color-mix(in oklab, var(--color-midnight-surface) 58%, transparent);
    backdrop-filter: blur(16px) saturate(1.6);
    -webkit-backdrop-filter: blur(16px) saturate(1.6);
    border-radius: var(--radius-full);
    box-shadow:
      var(--glass-rim),
      var(--glass-edge);
    transition:
      background-color 0.2s ease,
      backdrop-filter 0.2s ease,
      box-shadow 0.2s ease,
      height 0.2s ease,
      padding 0.2s ease;
  }
  /* Tighten + shrink the pill once the page scrolls past the hero (set by the
     inline script via data-scrolled); firm the glass up a touch so it stays
     legible over content. */
  .pill[data-scrolled] {
    height: 50px;
    padding-left: var(--spacing-16);
    background-color: color-mix(in oklab, var(--color-midnight-surface) 78%, transparent);
    backdrop-filter: blur(18px) saturate(1.7);
    -webkit-backdrop-filter: blur(18px) saturate(1.7);
    box-shadow:
      var(--glass-rim-strong),
      var(--glass-edge);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-8);
    color: var(--color-lilac-white);
    text-decoration: none;
    font-family: var(--font-aeonikpro);
    font-weight: 500;
    font-size: 15px;
    white-space: nowrap;
  }
  .brand-mark {
    color: var(--color-lavender-accent);
    flex-shrink: 0;
  }

  .links {
    display: flex;
    align-items: center;
    gap: var(--spacing-20);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .links a {
    position: relative;
    color: var(--color-ash);
    text-decoration: none;
    font-size: 15px;
    transition: color 0.18s ease;
  }
  /* Animated indicator: a thin cosmic underline that scales in from the left
     on hover and for the active section. */
  .links a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -4px;
    height: 2px;
    border-radius: var(--radius-full);
    background-image: var(--gradient-cosmic);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }
  .links a:hover {
    color: var(--color-lilac-white);
  }
  /* Active section — set by the inline scroll-spy script. */
  .links a[data-active] {
    color: var(--color-lilac-white);
  }
  .links a:hover::after,
  .links a[data-active]::after {
    transform: scaleX(1);
  }

  .actions {
    display: flex;
    align-items: center;
  }
  /* Round the CTA to a full pill so it echoes the nav shell rather than
     reading as a square button dropped inside it. Scoped to the nav — the
     global Button keeps its design-system radius elsewhere. */
  .actions :global(.btn) {
    border-radius: var(--radius-full);
  }

  /* Hamburger toggle — only rendered ≤720px (display set in the media query). */
  .menu-toggle {
    display: none;
    place-items: center;
    width: 40px;
    height: 40px;
    margin-right: -4px; /* optical: nudge the icon toward the pill edge */
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: var(--radius-full);
    color: var(--color-lilac-white);
    cursor: pointer;
    transition: color 0.18s ease;
  }
  .menu-toggle:hover {
    color: var(--color-lavender-accent);
  }
  /* Three bars: the span is the middle bar, ::before/::after the outer two. */
  .bars,
  .bars::before,
  .bars::after {
    content: '';
    display: block;
    width: 18px;
    height: 2px;
    border-radius: var(--radius-full);
    background-color: currentColor;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease,
      background-color 0.2s ease;
  }
  .bars {
    position: relative;
  }
  .bars::before {
    position: absolute;
    left: 0;
    top: -6px;
  }
  .bars::after {
    position: absolute;
    left: 0;
    top: 6px;
  }
  /* Open — bars morph into an ✕. */
  .menu-toggle[aria-expanded='true'] .bars {
    background-color: transparent;
  }
  .menu-toggle[aria-expanded='true'] .bars::before {
    transform: translateY(6px) rotate(45deg);
  }
  .menu-toggle[aria-expanded='true'] .bars::after {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Mobile dropdown panel — hidden entirely on desktop. */
  .menu {
    display: none;
  }
  .menu-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .menu-links a {
    display: flex;
    align-items: center;
    min-height: 44px; /* touch target (§8.5) */
    padding: var(--spacing-4) var(--spacing-8);
    border-radius: var(--radius-md);
    color: var(--color-ash);
    text-decoration: none;
    font-size: var(--text-body);
    transition:
      color 0.18s ease,
      background-color 0.18s ease;
  }
  .menu-links a:hover,
  .menu-links a[data-active] {
    color: var(--color-lilac-white);
  }
  .menu-links a[data-active] {
    background-color: color-mix(in oklab, var(--color-lavender-accent) 12%, transparent);
  }
  .menu .aurora-divider {
    margin: 0;
  }
  .menu :global(.btn) {
    width: 100%;
  }

  /* Below 720px: section links collapse into the hamburger dropdown. */
  @media (max-width: 720px) {
    .links {
      display: none;
    }
    /* CTA moves into the dropdown; the hamburger takes its place in the pill. */
    .nav-cta {
      display: none;
    }
    .menu-toggle {
      display: grid;
    }

    .menu {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-12);
      width: min(320px, calc(100vw - var(--spacing-32)));
      padding: var(--spacing-16);
      pointer-events: none;
      background-color: color-mix(in oklab, var(--color-midnight-surface) 80%, transparent);
      backdrop-filter: blur(18px) saturate(1.7);
      -webkit-backdrop-filter: blur(18px) saturate(1.7);
      border-radius: var(--radius-3xl);
      box-shadow:
        var(--glass-rim-strong),
        var(--glass-edge);
      opacity: 0;
      visibility: hidden;
      transform: translateY(-8px);
      transition:
        opacity 0.2s ease,
        transform 0.2s ease,
        visibility 0.2s ease;
    }
    .menu.is-open {
      opacity: 1;
      visibility: visible;
      transform: none;
      pointer-events: auto;
    }
  }
</style>

<script>
  // Scroll-spy + scrolled-state + mobile menu for the nav pill. Plain DOM, no
  // framework — bundled & minified by Astro, deferred (type=module). Reduced
  // motion is honored globally (smooth scroll + transitions frozen in CSS).
  const pill = document.querySelector('[data-nav-pill]');
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]'));

  // Links are root-anchored ("/#about"); match on the URL hash so scroll-spy
  // works whether the href is "#about" or "/#about". On sub-pages the target
  // sections don't exist, so the observer simply watches nothing.
  const sections = links
    .map((link) => (link.hash ? document.getElementById(link.hash.slice(1)) : null))
    .filter((el): el is HTMLElement => el !== null);

  const setActive = (id: string) => {
    for (const link of links) {
      const active = link.hash === `#${id}`;
      link.toggleAttribute('data-active', active);
      if (active) link.setAttribute('aria-current', 'location');
      else link.removeAttribute('aria-current');
    }
  };

  // The section crossing the viewport's vertical middle is the active one.
  const observer = new IntersectionObserver(
    (entries) => {
      const top = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
      if (top) setActive(top.target.id);
    },
    { rootMargin: '-45% 0px -45% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] },
  );
  sections.forEach((section) => observer.observe(section));

  const onScroll = () => {
    pill?.toggleAttribute('data-scrolled', window.scrollY > 24);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // --- Mobile dropdown menu -------------------------------------------------
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const menu = document.querySelector<HTMLElement>('[data-menu]');

  if (toggle && menu) {
    const focusables = () =>
      Array.from(menu.querySelectorAll<HTMLElement>('a[href], button:not([disabled])'));
    const isOpen = () => menu.classList.contains('is-open');

    const open = () => {
      menu.classList.add('is-open');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Close menu');
      focusables()[0]?.focus();
    };
    const close = (returnFocus = true) => {
      if (!isOpen()) return;
      menu.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open menu');
      if (returnFocus) toggle.focus();
    };

    toggle.addEventListener('click', () => (isOpen() ? close() : open()));

    // Tapping any link / the CTA navigates within the page → close the menu.
    menu
      .querySelectorAll('[data-menu-link]')
      .forEach((el) => el.addEventListener('click', () => close(false)));

    // Escape closes; Tab cycles within the open panel (lightweight focus trap).
    document.addEventListener('keydown', (e) => {
      if (!isOpen()) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        close();
        return;
      }
      if (e.key === 'Tab') {
        const items = focusables();
        if (!items.length) return;
        const first = items[0];
        const last = items[items.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    // Click outside the pill/menu closes.
    document.addEventListener('click', (e) => {
      const target = e.target as Node;
      if (isOpen() && !menu.contains(target) && !pill?.contains(target)) close(false);
    });

    // Leaving the mobile breakpoint resets the menu to a clean desktop state.
    matchMedia('(min-width: 721px)').addEventListener('change', (e) => {
      if (e.matches) close(false);
    });
  }
</script>

---
/**
 * NavPill — floating, centered pill navigation.
 * Static structure here; scroll-state (shrink/blur, active-section
 * highlighting) is added as a React island in the motion phase.
 */
import Button from './Button.astro';
import { site } from '../../data/site';

const links = [
  { label: 'About', href: '#about' },
  { label: 'Expertise', href: '#expertise' },
  { label: 'Projects', href: '#projects' },
  { label: 'Experience', href: '#experience' },
];
---

<nav class="nav-wrap" aria-label="Primary">
  <div class="pill">
    <a class="brand" href="#hero" aria-label={`${site.shortName} — home`}>
      <svg class="brand-mark" width="22" height="22" viewBox="0 0 32 32" aria-hidden="true">
        <g stroke="currentColor" stroke-width="1.1" stroke-linecap="round" opacity="0.7">
          <line x1="9" y1="11" x2="16" y2="7"></line>
          <line x1="16" y1="7" x2="23" y2="13"></line>
          <line x1="23" y1="13" x2="18" y2="22"></line>
          <line x1="18" y1="22" x2="9" y2="11"></line>
        </g>
        <g fill="currentColor">
          <circle cx="9" cy="11" r="1.6"></circle>
          <circle cx="16" cy="7" r="1.9"></circle>
          <circle cx="23" cy="13" r="1.6"></circle>
          <circle cx="18" cy="22" r="1.6"></circle>
        </g>
      </svg>
      <span class="brand-name">{site.shortName}</span>
    </a>

    <ul class="links">
      {
        links.map((link) => (
          <li>
            <a href={link.href}>{link.label}</a>
          </li>
        ))
      }
    </ul>

    <div class="actions">
      <Button href="#contact" size="sm">Get in touch</Button>
    </div>
  </div>
</nav>

<style>
  .nav-wrap {
    position: fixed;
    top: var(--spacing-20);
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    justify-content: center;
    padding-inline: var(--spacing-16);
    pointer-events: none;
  }

  .pill {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: var(--spacing-24);
    height: 56px;
    padding: var(--spacing-8) var(--spacing-8) var(--spacing-8) var(--spacing-20);
    background-color: color-mix(in oklab, var(--color-midnight-surface) 80%, transparent);
    backdrop-filter: blur(12px);
    border-radius: var(--radius-full);
    box-shadow: var(--glass-rim);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-8);
    color: var(--color-lilac-white);
    text-decoration: none;
    font-family: var(--font-aeonikpro);
    font-weight: 500;
    font-size: 15px;
    white-space: nowrap;
  }
  .brand-mark {
    color: var(--color-lavender-accent);
    flex-shrink: 0;
  }

  .links {
    display: flex;
    align-items: center;
    gap: var(--spacing-20);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .links a {
    color: var(--color-ash);
    text-decoration: none;
    font-size: 15px;
    transition: color 0.18s ease;
  }
  .links a:hover {
    color: var(--color-lilac-white);
  }

  .actions {
    display: flex;
    align-items: center;
  }

  /* Collapse the inline links on narrow viewports; a mobile menu island
     replaces them in a later phase. */
  @media (max-width: 720px) {
    .links {
      display: none;
    }
    .brand-name {
      display: none;
    }
  }
</style>

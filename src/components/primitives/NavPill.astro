---
/**
 * NavPill — floating, centered pill navigation.
 * Markup is server-rendered; the inline <script> below adds scroll-spy
 * (active link) + a `data-scrolled` flag with zero framework cost, keeping the
 * page's near-zero JS baseline (ULTRAPLAN §9: nav shrink/blur = CSS + scroll).
 * Richer active-pill / magnetic-CTA motion lands in the motion phase (Phase 6).
 */
import Button from './Button.astro';
import { site } from '../../data/site';

const links = [
  { label: 'About', href: '#about' },
  { label: 'Expertise', href: '#expertise' },
  { label: 'Projects', href: '#projects' },
  { label: 'Experience', href: '#experience' },
];
---

<nav class="nav-wrap" aria-label="Primary">
  <div class="pill" data-nav-pill>
    <a class="brand" href="#hero" aria-label={`${site.shortName} — home`}>
      <svg class="brand-mark" width="22" height="22" viewBox="0 0 32 32" aria-hidden="true">
        <g stroke="currentColor" stroke-width="1.1" stroke-linecap="round" opacity="0.7">
          <line x1="9" y1="11" x2="16" y2="7"></line>
          <line x1="16" y1="7" x2="23" y2="13"></line>
          <line x1="23" y1="13" x2="18" y2="22"></line>
          <line x1="18" y1="22" x2="9" y2="11"></line>
        </g>
        <g fill="currentColor">
          <circle cx="9" cy="11" r="1.6"></circle>
          <circle cx="16" cy="7" r="1.9"></circle>
          <circle cx="23" cy="13" r="1.6"></circle>
          <circle cx="18" cy="22" r="1.6"></circle>
        </g>
      </svg>
      <span class="brand-name">{site.shortName}</span>
    </a>

    <ul class="links">
      {
        links.map((link) => (
          <li>
            <a href={link.href} data-nav-link>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="actions">
      <Button href="#contact" size="sm">Get in touch</Button>
    </div>
  </div>
</nav>

<style>
  .nav-wrap {
    position: fixed;
    top: var(--spacing-20);
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    justify-content: center;
    padding-inline: var(--spacing-16);
    pointer-events: none;
  }

  .pill {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: var(--spacing-24);
    height: 56px;
    padding: var(--spacing-8) var(--spacing-8) var(--spacing-8) var(--spacing-20);
    background-color: color-mix(in oklab, var(--color-midnight-surface) 80%, transparent);
    backdrop-filter: blur(12px);
    border-radius: var(--radius-full);
    box-shadow: var(--glass-rim);
    transition:
      background-color 0.2s ease,
      box-shadow 0.2s ease;
  }
  /* Tighten the pill once the page scrolls past the hero (set by NavScroll). */
  .pill[data-scrolled] {
    background-color: color-mix(in oklab, var(--color-midnight-surface) 92%, transparent);
    box-shadow: var(--glass-rim-strong);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-8);
    color: var(--color-lilac-white);
    text-decoration: none;
    font-family: var(--font-aeonikpro);
    font-weight: 500;
    font-size: 15px;
    white-space: nowrap;
  }
  .brand-mark {
    color: var(--color-lavender-accent);
    flex-shrink: 0;
  }

  .links {
    display: flex;
    align-items: center;
    gap: var(--spacing-20);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .links a {
    color: var(--color-ash);
    text-decoration: none;
    font-size: 15px;
    transition: color 0.18s ease;
  }
  .links a:hover {
    color: var(--color-lilac-white);
  }
  /* Active section — set by the NavScroll island via scroll-spy. */
  .links a[data-active] {
    color: var(--color-lilac-white);
  }

  .actions {
    display: flex;
    align-items: center;
  }

  /* Collapse the inline links on narrow viewports; a mobile menu island
     replaces them in a later phase. */
  @media (max-width: 720px) {
    .links {
      display: none;
    }
    .brand-name {
      display: none;
    }
  }
</style>

<script>
  // Scroll-spy + scrolled-state for the nav pill. Plain DOM, no framework —
  // bundled & minified by Astro, deferred (type=module). Reduced-motion is
  // honored globally (smooth scroll disabled in global.css).
  const pill = document.querySelector('[data-nav-pill]');
  const links = Array.from(document.querySelectorAll('[data-nav-link]'));

  const sections = links
    .map((link) => {
      const id = link.getAttribute('href')?.slice(1);
      return id ? document.getElementById(id) : null;
    })
    .filter((el): el is HTMLElement => el !== null);

  const setActive = (id: string) => {
    for (const link of links) {
      const active = link.getAttribute('href') === `#${id}`;
      link.toggleAttribute('data-active', active);
      if (active) link.setAttribute('aria-current', 'location');
      else link.removeAttribute('aria-current');
    }
  };

  // The section crossing the viewport's vertical middle is the active one.
  const observer = new IntersectionObserver(
    (entries) => {
      const top = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
      if (top) setActive(top.target.id);
    },
    { rootMargin: '-45% 0px -45% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] },
  );
  sections.forEach((section) => observer.observe(section));

  const onScroll = () => {
    pill?.toggleAttribute('data-scrolled', window.scrollY > 24);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>

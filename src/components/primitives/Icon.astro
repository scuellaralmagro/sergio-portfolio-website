---
/**
 * Icon — outlined, 1.5px-stroke, 24px geometric icons (currentColor).
 * Brand marks (github, linkedin) render as fills; the rest are strokes.
 * Per the design system: stroke-based, minimal, no decorative fills.
 */
interface Props {
  name: IconName;
  size?: number;
  class?: string;
  /** Accessible label. Omit for purely decorative icons (aria-hidden). */
  title?: string;
}

type Glyph = { mode: 'stroke' | 'fill'; body: string };
const s = (body: string): Glyph => ({ mode: 'stroke', body });
const f = (body: string): Glyph => ({ mode: 'fill', body });

const icons = {
  sparkle: s('<path d="M12 3l1.8 6.2L20 11l-6.2 1.8L12 19l-1.8-6.2L4 11l6.2-1.8L12 3z"/>'),
  'arrow-right': s('<path d="M5 12h13"/><path d="M13 6l6 6-6 6"/>'),
  'arrow-up-right': s('<path d="M7 17L17 7"/><path d="M8 7h9v9"/>'),
  network: s(
    '<circle cx="18" cy="5" r="2.4"/><circle cx="6" cy="12" r="2.4"/><circle cx="18" cy="19" r="2.4"/><path d="M8.7 10.8l6.6-4.4M8.7 13.2l6.6 4.4"/>',
  ),
  database: s(
    '<ellipse cx="12" cy="5" rx="8" ry="3"/><path d="M4 5v6c0 1.66 3.58 3 8 3s8-1.34 8-3V5"/><path d="M4 11v6c0 1.66 3.58 3 8 3s8-1.34 8-3v-6"/>',
  ),
  workflow: s(
    '<rect x="3" y="4" width="6" height="6" rx="1.2"/><rect x="15" y="14" width="6" height="6" rx="1.2"/><path d="M9 7h4a3 3 0 0 1 3 3v4"/>',
  ),
  code: s('<path d="M8 9l-3.5 3L8 15"/><path d="M16 9l3.5 3L16 15"/><path d="M13.5 7l-3 10"/>'),
  layers: s(
    '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
  ),
  bot: s(
    '<rect x="4" y="8" width="16" height="11" rx="3"/><path d="M12 8V4M9 13h.01M15 13h.01M2 13v2M22 13v2"/>',
  ),
  globe: s(
    '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18"/>',
  ),
  mail: s('<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/>'),
  github: f(
    '<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>',
  ),
  linkedin: f(
    '<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>',
  ),
} satisfies Record<string, Glyph>;

export type IconName = keyof typeof icons;

const { name, size = 24, class: className, title } = Astro.props;
const icon = icons[name];
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={icon.mode === 'fill' ? 'currentColor' : 'none'}
  stroke={icon.mode === 'fill' ? 'none' : 'currentColor'}
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={['icon', className]}
  role={title ? 'img' : undefined}
  aria-hidden={title ? undefined : 'true'}
>
  {title && <title>{title}</title>}
  <Fragment set:html={icon.body} />
</svg>

---
/**
 * ConstellationField — the living constellation backdrop. A canvas of slowly
 * drifting "stars" (particles) that draw faint lines to nearby neighbours,
 * so constellations form and dissolve as they move — the agents-as-stars
 * metaphor, alive. Replaces the static StarField in the Hero and Footer.
 *
 * Purely decorative (aria-hidden, pointer-events:none, so clicks pass through).
 * Particle count scales with the canvas area (capped); the field pauses while
 * off-screen or when the tab is hidden, reacts subtly to a fine pointer, and
 * renders a single static frame under prefers-reduced-motion.
 */
interface Props {
  class?: string;
  /** Particle-density multiplier (1 = default). Lower = sparser. */
  density?: number;
  /** Link-distance multiplier (1 = default). Higher = more lines. */
  reach?: number;
}
const { class: className, density = 1, reach = 1 } = Astro.props;
---

<canvas
  class:list={['constellation-field', className]}
  aria-hidden="true"
  data-density={density}
  data-reach={reach}></canvas>

<style>
  .constellation-field {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
</style>

<script>
  type P = { x: number; y: number; vx: number; vy: number; r: number; a: number; tw: number };
  type RGB = [number, number, number];

  /** Read a `#rrggbb`/`#rgb` theme token off :root and parse to [r,g,b]. */
  function tokenRgb(name: string): RGB {
    const raw = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
    let h = raw.replace('#', '');
    if (h.length === 3) h = h.split('').map((c) => c + c).join('');
    const n = parseInt(h || 'f4f0ff', 16);
    return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
  }

  function initField(canvas: HTMLCanvasElement) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const fine = matchMedia('(pointer: fine)').matches;
    const density = Number(canvas.dataset.density) || 1;
    const reach = Number(canvas.dataset.reach) || 1;

    const dot = tokenRgb('--color-lilac-white'); // the stars
    const line = tokenRgb('--color-lavender-accent'); // the links

    let w = 0;
    let h = 0;
    let particles: P[] = [];
    let linkDist = 140;
    let raf = 0;
    let running = false;
    let t = 0;
    const pointer = { x: 0, y: 0, on: false };

    function seed() {
      const count = Math.max(18, Math.min(120, Math.round((w * h) / 16000) * density));
      particles = Array.from({ length: count }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.18,
        vy: (Math.random() - 0.5) * 0.18,
        r: Math.random() * 1.1 + 0.5,
        a: Math.random() * 0.5 + 0.45,
        tw: Math.random() * Math.PI * 2,
      }));
      linkDist = Math.min(150, Math.hypot(w, h) / 9) * reach;
    }

    function resize() {
      const rect = canvas.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      if (!w || !h) return;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      seed();
      if (reduce) draw();
    }

    function step() {
      t += 1;
      const R = linkDist * 1.4;
      for (const p of particles) {
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < -12) p.x = w + 12;
        else if (p.x > w + 12) p.x = -12;
        if (p.y < -12) p.y = h + 12;
        else if (p.y > h + 12) p.y = -12;
        if (pointer.on) {
          const dx = pointer.x - p.x;
          const dy = pointer.y - p.y;
          const d2 = dx * dx + dy * dy;
          if (d2 < R * R && d2 > 1) {
            const f = (1 - Math.sqrt(d2) / R) * 0.035;
            p.x += dx * f;
            p.y += dy * f;
          }
        }
      }
      draw();
    }

    function draw() {
      if (!ctx) return;
      ctx.clearRect(0, 0, w, h);
      ctx.lineWidth = 1;
      const R = linkDist * 1.4;
      for (let i = 0; i < particles.length; i++) {
        const a = particles[i];
        for (let j = i + 1; j < particles.length; j++) {
          const b = particles[j];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const d = Math.hypot(dx, dy);
          if (d < linkDist) {
            const o = (1 - d / linkDist) * 0.2;
            ctx.strokeStyle = `rgba(${line[0]},${line[1]},${line[2]},${o})`;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
          }
        }
        if (pointer.on) {
          const d = Math.hypot(a.x - pointer.x, a.y - pointer.y);
          if (d < R) {
            const o = (1 - d / R) * 0.24;
            ctx.strokeStyle = `rgba(${line[0]},${line[1]},${line[2]},${o})`;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(pointer.x, pointer.y);
            ctx.stroke();
          }
        }
      }
      for (const p of particles) {
        const a = reduce ? p.a : p.a * (0.7 + 0.3 * Math.sin(t * 0.02 + p.tw));
        ctx.fillStyle = `rgba(${dot[0]},${dot[1]},${dot[2]},${a})`;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    function loop() {
      step();
      raf = requestAnimationFrame(loop);
    }
    function start() {
      if (running || reduce || !w || !h) return;
      running = true;
      raf = requestAnimationFrame(loop);
    }
    function stop() {
      running = false;
      cancelAnimationFrame(raf);
    }
    function onScreen() {
      const r = canvas.getBoundingClientRect();
      return r.bottom > 0 && r.top < innerHeight;
    }

    new ResizeObserver(() => resize()).observe(canvas);
    resize();

    new IntersectionObserver(
      (entries) => {
        for (const e of entries) (e.isIntersecting ? start() : stop());
      },
      { threshold: 0 },
    ).observe(canvas);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop();
      else if (onScreen()) start();
    });

    if (fine && !reduce) {
      window.addEventListener(
        'pointermove',
        (e) => {
          const r = canvas.getBoundingClientRect();
          const x = e.clientX - r.left;
          const y = e.clientY - r.top;
          pointer.on = x >= 0 && y >= 0 && x <= r.width && y <= r.height;
          if (pointer.on) {
            pointer.x = x;
            pointer.y = y;
          }
        },
        { passive: true },
      );
      window.addEventListener('blur', () => (pointer.on = false));
    }
  }

  function init() {
    document.querySelectorAll<HTMLCanvasElement>('.constellation-field').forEach((c) => {
      if (c.dataset.init) return;
      c.dataset.init = '1';
      initField(c);
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
</script>

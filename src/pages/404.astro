---
/**
 * 404 — on-brand cosmic not-found page. Astro emits this to dist/404.html,
 * which Cloudflare serves via `not_found_handling: "404-page"` (wrangler.jsonc).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/primitives/Button.astro';
import StarField from '../components/primitives/StarField.astro';
import { useTranslations, type Locale } from '../i18n/utils';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = useTranslations(locale);
---

<BaseLayout title={t('notFound.pageTitle')} noindex>
  <main id="main" class="notfound">
    <StarField count={80} class="nf-stars" />
    <div class="nf-inner">
      <p class="code text-cosmic">404</p>
      <h1>{t('notFound.title')}</h1>
      <p class="msg">{t('notFound.msg')}</p>
      <Button href="/">{t('notFound.home')}</Button>
    </div>
  </main>
</BaseLayout>

<style>
  .notfound {
    position: relative;
    min-height: 100dvh;
    display: grid;
    place-items: center;
    padding: var(--spacing-24);
    overflow: hidden;
  }
  .nf-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-16);
    text-align: center;
  }
  .code {
    font-family: var(--font-dm-sans);
    font-weight: 500;
    font-size: var(--text-display);
    line-height: 1;
  }
  .msg {
    margin: 0 0 var(--spacing-8);
    max-width: 44ch;
    color: var(--color-ash);
  }
</style>

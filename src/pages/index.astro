---
/**
 * Home — single-page immersive scroll (ULTRAPLAN §4).
 * Phase 2 establishes the layout & scroll skeleton: floating nav with
 * scroll-spy, all anchored sections (Hero → Contact), and the footer.
 * Section bodies are placeholders; real content lands in Phases 3–6.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import NavPill from '../components/primitives/NavPill.astro';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import Expertise from '../components/sections/Expertise.astro';
import AIShowcase from '../components/sections/AIShowcase.astro';
import Projects from '../components/sections/Projects.astro';
import Experience from '../components/sections/Experience.astro';
import Contact from '../components/sections/Contact.astro';
import Footer from '../components/sections/Footer.astro';
---

<BaseLayout>
  <NavPill />
  <main id="main">
    <Hero />
    <About />
    <Expertise />
    <AIShowcase />
    <Projects />
    <Experience />
    <Contact />
  </main>
  <Footer />
</BaseLayout>

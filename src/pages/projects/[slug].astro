---
/**
 * /projects/[slug] — project case-study page (ULTRAPLAN §4.3).
 * Hero (title, role/period, stack chips, links) → rendered MDX body
 * (Problem → Architecture → Role & decisions → Outcome) → prev/next nav.
 * Pages are generated from the typed `projects` content collection.
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavPill from '../../components/primitives/NavPill.astro';
import Footer from '../../components/sections/Footer.astro';
import TextLink from '../../components/primitives/TextLink.astro';
import AuroraDivider from '../../components/primitives/AuroraDivider.astro';

export async function getStaticPaths() {
  const entries = (await getCollection('projects', ({ data }) => !data.draft)).sort(
    (a, b) => a.data.order - b.data.order,
  );
  return entries.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: entries[i - 1] ?? null,
      next: entries[i + 1] ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
const { title, summary, role, company, period, stack, repo, live, note } = entry.data;

const meta = [role, company, period].filter(Boolean).join(' · ');
---

<BaseLayout title={title} description={summary}>
  <NavPill />
  <main id="main" class="case">
    <article>
      <header class="hero">
        <a class="back" href="/#projects">← All projects</a>
        <h1>{title}</h1>
        {meta && <p class="meta">{meta}</p>}
        <p class="summary">{summary}</p>

        <ul class="stack">
          {stack.map((tech) => <li class="chip">{tech}</li>)}
        </ul>

        <div class="links">
          {
            repo ? (
              <TextLink href={repo} external>
                View code
              </TextLink>
            ) : (
              note && <span class="note">{note}</span>
            )
          }
          {
            live && (
              <TextLink href={live} external>
                Live
              </TextLink>
            )
          }
        </div>
      </header>

      <AuroraDivider class="hero-rule" />

      <div class="prose">
        <Content />
      </div>
    </article>

    {
      (prev || next) && (
        <nav class="pager" aria-label="More projects">
          {prev ? (
            <a class="pager-link prev" href={`/projects/${prev.id}`}>
              <span class="pager-dir">← Previous</span>
              <span class="pager-title">{prev.data.title}</span>
            </a>
          ) : (
            <span />
          )}
          {next && (
            <a class="pager-link next" href={`/projects/${next.id}`}>
              <span class="pager-dir">Next →</span>
              <span class="pager-title">{next.data.title}</span>
            </a>
          )}
        </nav>
      )
    }
  </main>
  <Footer />
</BaseLayout>

<style>
  .case {
    max-width: 820px;
    margin-inline: auto;
    padding: 140px var(--spacing-24) var(--spacing-72);
  }

  .back {
    display: inline-block;
    margin-bottom: var(--spacing-24);
    color: var(--color-fog);
    font-size: var(--text-body-sm);
  }
  .back:hover {
    color: var(--color-lilac-white);
  }

  .hero {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-16);
  }
  .hero h1 {
    font-size: var(--text-heading);
    line-height: var(--leading-heading);
    letter-spacing: var(--tracking-heading);
  }
  .meta {
    margin: 0;
    color: var(--color-lavender-accent);
    font-size: var(--text-body-sm);
  }
  .summary {
    margin: 0;
    max-width: 60ch;
    color: var(--color-ash);
    font-size: var(--text-body-lg);
    line-height: var(--leading-body-lg);
  }

  .stack {
    list-style: none;
    margin: var(--spacing-8) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
  }
  .chip {
    padding: var(--spacing-4) var(--spacing-12);
    border: 1px solid var(--color-iris);
    border-radius: var(--radius-3xl-2);
    color: var(--color-mercury);
    font-size: var(--text-caption);
    line-height: 1.4;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-20);
  }
  .note {
    color: var(--color-fog);
    font-size: var(--text-body-sm);
  }

  .hero-rule {
    margin-block: var(--spacing-48);
  }

  /* MDX-rendered case-study body */
  .prose :global(h2) {
    font-size: var(--text-subheading);
    line-height: var(--leading-subheading);
    color: var(--color-lilac-white);
    margin-block: var(--spacing-48) var(--spacing-16);
  }
  .prose :global(p) {
    margin-block: 0 var(--spacing-16);
    color: var(--color-ash);
    line-height: var(--leading-body);
  }
  .prose :global(ul) {
    margin-block: 0 var(--spacing-16);
    padding-left: var(--spacing-20);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-12);
    color: var(--color-ash);
  }
  .prose :global(li::marker) {
    color: var(--color-lavender-accent);
  }
  .prose :global(strong) {
    color: var(--color-lilac-white);
    font-weight: 500;
  }
  .prose :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.9em;
    color: var(--color-mercury);
    background-color: var(--color-deep-indigo);
    padding: 0.1em 0.4em;
    border-radius: var(--radius-md);
  }
  .prose :global(a) {
    color: var(--color-lavender-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose :global(blockquote) {
    margin: var(--spacing-24) 0;
    padding: var(--spacing-16) var(--spacing-20);
    border-left: 2px solid var(--color-lavender-accent);
    background-color: var(--color-midnight-surface);
    border-radius: var(--radius-md);
    color: var(--color-fog);
  }
  .prose :global(blockquote p) {
    margin: 0;
  }
  /* Reused ArchDiagram figures (e.g. the Kynetix orchestration graph) */
  .prose :global(figure) {
    margin: var(--spacing-24) 0 var(--spacing-32);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-12);
  }
  .prose :global(figcaption) {
    color: var(--color-fog);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body-sm);
  }

  .pager {
    display: flex;
    justify-content: space-between;
    gap: var(--spacing-16);
    margin-top: var(--spacing-72);
  }
  .pager-link {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
    color: var(--color-ash);
    text-decoration: none;
    max-width: 48%;
  }
  .pager-link.next {
    text-align: right;
    margin-left: auto;
  }
  .pager-dir {
    font-size: var(--text-caption);
    color: var(--color-fog);
  }
  .pager-title {
    color: var(--color-lilac-white);
    font-size: var(--text-body-sm);
  }
  .pager-link:hover .pager-title {
    color: var(--color-lavender-accent);
  }

  @media (min-width: 768px) {
    .hero h1 {
      font-size: var(--text-heading-lg);
      line-height: var(--leading-heading-lg);
      letter-spacing: var(--tracking-heading-lg);
    }
  }
</style>
